{
  "name": "baikal-home-assist",
  "version": "0.1.0",
  "description": "Baikal — a Telegram home assistant bot powered by pi.dev agent SDK",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node --loader tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "eslint src/ --fix"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.70.6",
    "dotenv": "^16.4.5",
    "telegraf": "^4.16.3",
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "jiti": "^2.6.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
